{
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "ignore": [
        "node_modules",
        ".git",
        "*.log",
        ".env",
        ".env.local"
      ]
    }
  ],
  "hosting": {
    "public": "hosting-public",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/relay",
        "run": {
          "serviceId": "firestorerelay",
          "region": "us-central1"
        }
      }
    ]
  }
}
